// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model ScrollToTopSettings {
  id                   String   @id @default(cuid())
  shop                 String   @unique
  // General
  isEnabled            Boolean  @default(true)
  // Design
  iconType             String   @default("arrow")
  buttonShape          String   @default("circle")
  buttonSize           Int      @default(50)
  iconSize             Int      @default(20)
  borderRadius         Int      @default(50)
  borderWidth          Int      @default(0)
  opacity              Float    @default(1.0)
  // Colors
  buttonColor          String   @default("#000000")
  iconColor            String   @default("#ffffff")
  hoverBackgroundColor String   @default("#333333")
  hoverIconColor       String   @default("#ffffff")
  borderColor          String   @default("#000000")
  shadowColor          String   @default("#000000")
  // Position
  buttonPosition       String   @default("bottom-right")
  bottomOffset         Int      @default(20)
  sideOffset           Int      @default(20)
  // Visibility
  showOnDesktop        Boolean  @default(true)
  showOnMobile         Boolean  @default(true)
  hideAtTop            Boolean  @default(false)
  // Scroll
  scrollThreshold      Int      @default(300)
  scrollSpeed          String   @default("medium")
  // Animation
  animationType        String   @default("fade")
  // Shadow
  enableShadow         Boolean  @default(false)
  shadowBlur           Int      @default(10)
  shadowOpacity        Float    @default(0.3)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
