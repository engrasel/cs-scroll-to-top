# ── Shopify App ────────────────────────────────────────────────
# Found in Shopify Partner Dashboard → Apps → your app → API credentials
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# The public URL of this app (your Railway domain after first deploy)
SHOPIFY_APP_URL=https://your-app.up.railway.app

# Scopes declared in shopify.app.toml [access_scopes]
SCOPES=write_products,write_metaobjects,write_metaobject_definitions

# ── Database ───────────────────────────────────────────────────
# Automatically injected by Railway when a PostgreSQL service is
# added to the project. Do NOT set this manually on Railway.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Runtime ────────────────────────────────────────────────────
NODE_ENV=production
